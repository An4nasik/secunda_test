# Скопируйте в .env и настройте под себя: cp .env.example .env
# Все переменные имеют значения по умолчанию — compose поднимется и без .env.

# Статический ключ API (заголовок X-API-Key)
API_KEY=dev-secret-key

# Эмуляция платёжного шлюза
GATEWAY_DELAY_MIN_SECONDS=2.0
GATEWAY_DELAY_MAX_SECONDS=5.0
GATEWAY_SUCCESS_RATE=0.9

# Политика ретраев consumer'а (задержка перед попыткой N: base * 2^(N-1))
MAX_RETRIES=3
RETRY_BASE_DELAY_SECONDS=2.0

# Доставка вебхуков
WEBHOOK_TIMEOUT_SECONDS=10.0

# Логи
LOG_LEVEL=INFO
LOG_JSON=true

# Для локального запуска сервисов без Docker (uv run python -m app.api):
# DATABASE_URL=postgresql+asyncpg://payments:payments@localhost:5432/payments
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/
